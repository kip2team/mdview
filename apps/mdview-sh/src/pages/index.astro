---
// mdview.sh 首页 —— 重做版
// 设计目标:
//  1. Hero 一眼传达「粘贴一个 .md URL 就读」的卖点,并附带视觉化预览
//  2. 一键试用样例(知名仓库 README),降低首次体验门槛
//  3. 用真实的 surface 矩阵(Desktop / CLI / Web / Browser-ext / MCP)展示生态
//  4. 主题缩略图 + .mdv.html 杀手特性的可视化解释
//  5. 暗色模式、移动端、可访问性

import Base from '../layouts/Base.astro';

// 如果 URL 上带了 ?url= 直接重定向到 /preview
const urlParam = Astro.url.searchParams.get('url');
if (urlParam) {
  return Astro.redirect(`/preview?url=${encodeURIComponent(urlParam)}`);
}

// 一键试用样例 —— 选高知名度、稳定、纯 Markdown 的 README
const samples = [
  {
    label: 'React',
    url: 'https://raw.githubusercontent.com/facebook/react/main/README.md',
  },
  {
    label: 'Tauri',
    url: 'https://raw.githubusercontent.com/tauri-apps/tauri/dev/README.md',
  },
  {
    label: 'Astro',
    url: 'https://raw.githubusercontent.com/withastro/astro/main/README.md',
  },
  {
    label: 'TypeScript',
    url: 'https://raw.githubusercontent.com/microsoft/TypeScript/main/README.md',
  },
];

// 多端矩阵 —— 真实存在的发行渠道
const surfaces = [
  {
    name: 'Web',
    tag: 'mdview.sh',
    desc: 'Paste a URL, get a beautifully rendered, shareable page. SSR on Cloudflare.',
    cta: { label: 'You are here', href: '#hero' },
    accent: '#0969da',
  },
  {
    name: 'Desktop',
    tag: 'macOS · auto-update',
    desc: 'Native window with tabs, drag-and-drop, double-click .md to open. Tauri 2.',
    cta: { label: 'Download .dmg', href: 'https://github.com/kip2team/mdview/releases/latest' },
    accent: '#a371f7',
  },
  {
    name: 'CLI',
    tag: 'npx @mdview/cli',
    desc: 'Render a .md to a single self-contained .mdv.html — share, archive, edit in any editor.',
    cta: { label: 'View on npm', href: 'https://www.npmjs.com/package/@mdview/cli' },
    accent: '#1f883d',
  },
  {
    name: 'Browser Ext',
    tag: 'Chrome · Firefox',
    desc: 'Auto-render raw .md pages anywhere you encounter them on the web.',
    cta: { label: 'Source', href: 'https://github.com/kip2team/mdview/tree/main/packages/browser-ext' },
    accent: '#cf222e',
  },
  {
    name: 'MCP',
    tag: '@mdview/mcp',
    desc: 'Give Claude / agents a markdown rendering tool. Stdio MCP server.',
    cta: { label: 'View on npm', href: 'https://www.npmjs.com/package/@mdview/mcp' },
    accent: '#d4a72c',
  },
  {
    name: 'Embed',
    tag: 'cdn.mdview.sh',
    desc: 'Drop the engine into any HTML page with a single <script> tag.',
    cta: { label: 'Read docs', href: '/docs' },
    accent: '#fb8500',
  },
];

// 主题缩略 —— 与 packages/themes/src/themes/* 保持一致
const themes = [
  { id: 'default',   label: 'Default',   bg: '#ffffff', fg: '#1f2328', accent: '#0969da' },
  { id: 'github',    label: 'GitHub',    bg: '#ffffff', fg: '#1f2328', accent: '#0969da' },
  { id: 'medium',    label: 'Medium',    bg: '#fffefb', fg: '#292929', accent: '#1a8917' },
  { id: 'sepia',     label: 'Sepia',     bg: '#f4ecd8', fg: '#5b4636', accent: '#ad6534' },
  { id: 'solarized', label: 'Solarized', bg: '#fdf6e3', fg: '#586e75', accent: '#268bd2' },
  { id: 'dark',      label: 'Dark',      bg: '#0d1117', fg: '#e6edf3', accent: '#4493f8' },
];
---

<Base>
  <header class="topbar">
    <a class="brand" href="/" aria-label="mdview">
      <picture class="brand-mark-wrap">
        <source
          srcset="/logo-dark.png 1x, /logo-dark@2x.png 2x"
          media="(prefers-color-scheme: dark)"
        />
        <img
          class="brand-mark"
          src="/logo.png"
          srcset="/logo.png 1x, /logo@2x.png 2x"
          width="32"
          height="32"
          alt=""
        />
      </picture>
      <picture class="brand-wordmark">
        <source
          srcset="/logo-wordmark-dark.png 1x, /logo-wordmark-dark@2x.png 2x"
          media="(prefers-color-scheme: dark)"
        />
        <img
          src="/logo-wordmark.png"
          srcset="/logo-wordmark.png 1x, /logo-wordmark@2x.png 2x"
          alt="mdview"
        />
      </picture>
    </a>
    <nav class="topnav">
      <a href="/docs">Docs</a>
      <a href="https://github.com/kip2team/mdview/releases/latest">Download</a>
      <a href="https://github.com/kip2team/mdview" class="topnav-github" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38v-1.33c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.06-.49.06-.49.81.06 1.23.83 1.23.83.72 1.22 1.87.87 2.33.67.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.19c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
      </a>
    </nav>
  </header>

  <main>
    <section id="hero" class="hero">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="hero-inner">
        <h1>
          Markdown,<br />
          <span class="grad">beautifully rendered.</span>
        </h1>
        <p class="lede">
          Paste any <code>.md</code> URL — read it like a real document.
          Theme-able, shareable, archivable. Open source.
        </p>

        <form action="/preview" method="GET" class="url-form" role="search">
          <span class="url-form-leading" aria-hidden="true">↗</span>
          <input
            type="url"
            name="url"
            placeholder="https://raw.githubusercontent.com/.../README.md"
            required
            autofocus
            aria-label="Markdown URL"
          />
          <button type="submit">Render</button>
        </form>

        <div class="samples">
          <span class="samples-label">Or try:</span>
          {samples.map((s) => (
            <a class="sample-chip" href={`/preview?url=${encodeURIComponent(s.url)}`}>
              {s.label}
            </a>
          ))}
          <a class="sample-chip sample-chip-demo" href="/docs/demo">Full demo</a>
        </div>

        <!-- Hero 视觉:URL → rendered card 的"前后对比" -->
        <div class="hero-visual" aria-hidden="true">
          <div class="hv-card hv-card-url">
            <div class="hv-dots"><i></i><i></i><i></i></div>
            <div class="hv-url"># Hello World</div>
            <div class="hv-url hv-muted">Just **markdown**, raw and ugly</div>
            <div class="hv-url hv-muted">- one</div>
            <div class="hv-url hv-muted">- two</div>
            <div class="hv-url hv-muted">```js</div>
            <div class="hv-url hv-muted hv-mono">console.log('hi')</div>
            <div class="hv-url hv-muted">```</div>
          </div>
          <div class="hv-arrow">→</div>
          <div class="hv-card hv-card-rendered">
            <div class="hv-dots"><i></i><i></i><i></i></div>
            <h3>Hello World</h3>
            <p>Just <strong>markdown</strong>, beautifully rendered</p>
            <ul><li>one</li><li>two</li></ul>
            <pre><code>console.log(<span class="tok-str">'hi'</span>)</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="surfaces">
      <header class="section-head">
        <p class="kicker">One engine</p>
        <h2>Same Markdown, every surface.</h2>
        <p class="sub">From your terminal to your menu bar to your AI agent.</p>
      </header>
      <div class="surfaces-grid">
        {surfaces.map((s) => (
          <article class="surface-card" style={`--accent: ${s.accent}`}>
            <div class="surface-head">
              <span class="surface-name">{s.name}</span>
              <span class="surface-tag">{s.tag}</span>
            </div>
            <p class="surface-desc">{s.desc}</p>
            <a class="surface-cta" href={s.cta.href}>{s.cta.label} →</a>
          </article>
        ))}
      </div>
    </section>

    <section class="mdvhtml">
      <div class="mdvhtml-copy">
        <p class="kicker">Killer feature</p>
        <h2>The <code>.mdv.html</code> format.</h2>
        <p>
          Export your rendered page as a single HTML file. Open it in any browser — it renders itself.
          Open it in any text editor — the body is still your <strong>original Markdown</strong>.
        </p>
        <p class="mdvhtml-sub">
          One file. Self-contained. No build step. No server required. Diffable in git.
        </p>
        <a class="link-arrow" href="https://github.com/kip2team/mdview/blob/main/docs/02-Format-Spec.md">
          Read the spec →
        </a>
      </div>
      <pre class="mdvhtml-code"><code><span class="tok-tag">&lt;!doctype html&gt;</span>
<span class="tok-tag">&lt;html&gt;</span>
<span class="tok-tag">&lt;head&gt;</span>
  <span class="tok-tag">&lt;script</span> <span class="tok-attr">src=</span><span class="tok-str">"https://cdn.mdview.sh/r/engine.js"</span>
          <span class="tok-attr">data-mdview-engine</span><span class="tok-tag">&gt;&lt;/script&gt;</span>
  <span class="tok-tag">&lt;link</span> <span class="tok-attr">rel=</span><span class="tok-str">"stylesheet"</span>
        <span class="tok-attr">href=</span><span class="tok-str">"https://cdn.mdview.sh/themes/medium.css"</span><span class="tok-tag">&gt;</span>
<span class="tok-tag">&lt;/head&gt;</span>
<span class="tok-tag">&lt;body&gt;</span>
  <span class="tok-comment"># Hello, world</span>

  <span class="tok-comment">This file is **both** a webpage AND</span>
  <span class="tok-comment">a plain Markdown document.</span>
<span class="tok-tag">&lt;/body&gt;</span>
<span class="tok-tag">&lt;/html&gt;</span></code></pre>
    </section>

    <section class="themes">
      <header class="section-head">
        <p class="kicker">Themes</p>
        <h2>Pick a reading mood.</h2>
        <p class="sub">Six built-in themes. Or bring your own CSS.</p>
      </header>
      <div class="themes-grid">
        {themes.map((t) => (
          <div class="theme-card" style={`--bg:${t.bg};--fg:${t.fg};--accent:${t.accent}`}>
            <div class="theme-preview">
              <div class="theme-h">Aa</div>
              <div class="theme-line"></div>
              <div class="theme-line theme-line-2"></div>
              <div class="theme-line theme-line-3"></div>
            </div>
            <div class="theme-label">{t.label}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="cta">
      <h2>Start reading.</h2>
      <p>It's a URL away.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="#hero">Render a URL</a>
        <a class="btn btn-ghost" href="https://github.com/kip2team/mdview/releases/latest">
          Download desktop
        </a>
      </div>
    </section>
  </main>

  <footer class="sitefoot">
    <div class="sitefoot-row">
      <span class="sitefoot-brand">mdview</span>
      <span class="sitefoot-sep">·</span>
      <a href="https://github.com/kip2team/mdview">GitHub</a>
      <a href="/docs">Docs</a>
      <a href="https://www.npmjs.com/org/mdview">npm</a>
      <a href="https://github.com/kip2team/mdview/blob/main/docs/02-Format-Spec.md">.mdv.html spec</a>
    </div>
    <div class="sitefoot-row sitefoot-muted">
      <span>MIT licensed</span>
      <span class="sitefoot-sep">·</span>
      <span>Made for readers.</span>
    </div>
  </footer>
</Base>

<style>
  /* ── Topbar ───────────────────────────────────────── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg, #ffffff) 78%, transparent);
    border-bottom: 1px solid color-mix(in srgb, currentColor 8%, transparent);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: inherit;
  }
  .brand-mark {
    width: 30px;
    height: 30px;
    display: block;
    /* 透明背景 PNG,给个柔和投影提升立体感 */
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.15));
  }
  .brand-wordmark {
    display: inline-flex;
  }
  .brand-wordmark img {
    display: block;
    height: 22px;
    width: auto;
  }
  .topnav {
    display: flex;
    align-items: center;
    gap: 22px;
    font-size: 14px;
  }
  .topnav a {
    color: inherit;
    text-decoration: none;
    opacity: 0.75;
  }
  .topnav a:hover { opacity: 1; }
  .topnav-github {
    display: inline-flex;
    align-items: center;
    opacity: 0.6;
  }

  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    position: relative;
    padding: 96px 28px 64px;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(800px 400px at 20% 10%, rgba(9, 105, 218, 0.12), transparent 70%),
      radial-gradient(700px 360px at 80% 30%, rgba(163, 113, 247, 0.10), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    max-width: 1080px;
    margin: 0 auto;
    z-index: 1;
  }
  .hero h1 {
    font-size: clamp(40px, 6.5vw, 76px);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0 0 18px;
  }
  .grad {
    background: linear-gradient(90deg, #0969da 0%, #a371f7 60%, #fb8500 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lede {
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.55;
    max-width: 620px;
    margin: 0 0 36px;
    opacity: 0.72;
  }
  .lede code {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.9em;
    padding: 0.1em 0.4em;
    border-radius: 4px;
    background: color-mix(in srgb, currentColor 8%, transparent);
  }

  /* URL form */
  .url-form {
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: 680px;
    padding: 6px;
    background: color-mix(in srgb, var(--bg, #ffffff) 85%, transparent);
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    border-radius: 14px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
    transition: border-color 120ms, box-shadow 120ms;
  }
  .url-form:focus-within {
    border-color: #0969da;
    box-shadow: 0 0 0 4px rgba(9, 105, 218, 0.15);
  }
  .url-form-leading {
    padding: 0 8px 0 14px;
    opacity: 0.4;
    font-size: 18px;
  }
  .url-form input {
    flex: 1;
    padding: 12px 0;
    background: transparent;
    border: 0;
    outline: 0;
    font-size: 15px;
    color: inherit;
    font-family: inherit;
  }
  .url-form input::placeholder {
    color: color-mix(in srgb, currentColor 38%, transparent);
  }
  .url-form button {
    padding: 11px 22px;
    border: 0;
    border-radius: 9px;
    background: linear-gradient(180deg, #0a73e6, #0859b6);
    color: #ffffff;
    font: inherit;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: transform 80ms, box-shadow 120ms;
    box-shadow: 0 2px 8px rgba(9, 105, 218, 0.35);
  }
  .url-form button:hover { box-shadow: 0 4px 14px rgba(9, 105, 218, 0.5); }
  .url-form button:active { transform: translateY(1px); }

  .samples {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin: 18px 0 0;
    font-size: 13px;
  }
  .samples-label {
    opacity: 0.55;
    margin-right: 2px;
  }
  .sample-chip {
    display: inline-flex;
    align-items: center;
    padding: 5px 11px;
    border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    border-radius: 999px;
    color: inherit;
    text-decoration: none;
    font-size: 12.5px;
    opacity: 0.78;
    transition: all 120ms;
  }
  .sample-chip:hover {
    opacity: 1;
    border-color: color-mix(in srgb, currentColor 30%, transparent);
    background: color-mix(in srgb, currentColor 4%, transparent);
  }
  .sample-chip-demo {
    border-color: color-mix(in srgb, #0969da 30%, transparent);
    color: #0969da;
  }

  /* Hero visual: before/after */
  .hero-visual {
    margin: 64px auto 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
    max-width: 920px;
    transform-style: preserve-3d;
    perspective: 1200px;
  }
  .hv-card {
    background: var(--bg, #ffffff);
    border: 1px solid color-mix(in srgb, currentColor 10%, transparent);
    border-radius: 12px;
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.18);
    padding: 14px 18px 18px;
    min-height: 220px;
    transition: transform 200ms;
  }
  .hv-card-url {
    transform: rotateY(6deg);
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 12.5px;
    color: color-mix(in srgb, currentColor 80%, transparent);
  }
  .hv-card-rendered {
    transform: rotateY(-6deg);
  }
  .hv-dots {
    display: flex;
    gap: 6px;
    margin-bottom: 14px;
  }
  .hv-dots i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: color-mix(in srgb, currentColor 18%, transparent);
  }
  .hv-url { line-height: 1.6; }
  .hv-muted { opacity: 0.7; }
  .hv-mono { padding-left: 10px; }
  .hv-arrow {
    font-size: 28px;
    opacity: 0.35;
    text-align: center;
  }
  .hv-card-rendered h3 {
    margin: 0 0 6px;
    font-size: 16px;
    font-weight: 700;
  }
  .hv-card-rendered p {
    margin: 0 0 10px;
    font-size: 13.5px;
    line-height: 1.55;
  }
  .hv-card-rendered ul {
    margin: 0 0 10px;
    padding-left: 18px;
    font-size: 13px;
  }
  .hv-card-rendered ul li { line-height: 1.55; }
  .hv-card-rendered pre {
    margin: 0;
    padding: 8px 10px;
    background: color-mix(in srgb, currentColor 6%, transparent);
    border-radius: 6px;
    font-size: 12px;
    font-family: ui-monospace, SFMono-Regular, monospace;
  }
  .tok-str { color: #1f883d; }

  /* ── Section head ─────────────────────────────────── */
  .section-head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 40px;
  }
  .kicker {
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 11.5px;
    font-weight: 600;
    color: #0969da;
    opacity: 0.9;
  }
  .section-head h2 {
    margin: 0 0 10px;
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .section-head .sub {
    margin: 0;
    opacity: 0.65;
    font-size: 15px;
  }

  /* ── Surfaces grid ────────────────────────────────── */
  .surfaces {
    padding: 80px 28px;
    max-width: 1080px;
    margin: 0 auto;
  }
  .surfaces-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }
  .surface-card {
    position: relative;
    padding: 22px 22px 20px;
    background: color-mix(in srgb, var(--bg, #ffffff) 95%, transparent);
    border: 1px solid color-mix(in srgb, currentColor 10%, transparent);
    border-radius: 14px;
    transition: transform 160ms, border-color 160ms, box-shadow 160ms;
    overflow: hidden;
  }
  .surface-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--accent);
    opacity: 0.85;
  }
  .surface-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    box-shadow: 0 10px 30px -12px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .surface-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }
  .surface-name {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .surface-tag {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 11.5px;
    opacity: 0.55;
  }
  .surface-desc {
    margin: 0 0 14px;
    font-size: 13.5px;
    line-height: 1.55;
    opacity: 0.72;
  }
  .surface-cta {
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
  }
  .surface-cta:hover { text-decoration: underline; }

  /* ── .mdv.html section ────────────────────────────── */
  .mdvhtml {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
