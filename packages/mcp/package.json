{
  "name": "@mdview/mcp",
  "version": "0.0.1",
  "description": "MCP server exposing mdview rendering tools to Claude / other AI assistants.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "mdview-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node ./dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mdview/core": "workspace:*",
    "@mdview/format": "workspace:*",
    "@mdview/themes": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4"
  }
}
